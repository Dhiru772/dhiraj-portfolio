datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  project   String
  createdAt DateTime @default(now())
}

model BlogComment {
  id        String   @id @default(uuid())
  slug      String   @db.Text
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([slug])
}
